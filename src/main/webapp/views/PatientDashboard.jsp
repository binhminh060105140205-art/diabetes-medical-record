<%@page contentType="text/html" pageEncoding="UTF-8"%><%@taglib prefix="c" uri="jakarta.tags.core"%>
<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Sức khỏe hôm nay — DiaCare</title><link rel="stylesheet" href="${pageContext.request.contextPath}/static/css/style.css"></head><body><jsp:include page="header.jsp"/><jsp:include page="topnav.jsp"/><main class="page-wrapper"><div class="page-heading"><div><div class="eyebrow">THEO DÕI HẰNG NGÀY</div><h1 class="page-title">Sức khỏe hôm nay</h1><p class="text-muted">Ghi một lần mỗi ngày; bạn có thể cập nhật lại nếu nhập nhầm.</p></div><a class="btn btn-outline-dark" href="${pageContext.request.contextPath}/PatientJournal">Xem nhật ký 30 ngày</a></div><c:if test="${not empty msg}"><div class="alert alert-info"><c:out value="${msg}"/></div></c:if><c:if test="${not empty patient}"><c:if test="${not empty unacknowledgedAlerts}"><section class="card"><div class="card-title">Cảnh báo cần lưu ý</div><c:forEach var="alert" items="${unacknowledgedAlerts}"><div class="alert alert-warning" id="alert-${alert.alertId}"><strong><c:out value="${alert.alertMessage}"/></strong><button class="btn btn-sm btn-outline-dark" type="button" onclick="ackAlert(${alert.alertId})">Đã hiểu</button></div></c:forEach></section></c:if><div class="two-column"><section class="card"><div class="card-title">Nhập chỉ số hôm nay <c:if test="${not empty todayLog}"><span class="status-pill status-COMPLETED">Đã nhập</span></c:if></div><div class="form-group"><label>Đường huyết (mg/dL)</label><input type="number" min="20" max="600" step="0.1" id="log_bg" class="form-control" value="${todayLog.bloodGlucose}" placeholder="Ví dụ: 105"></div><div class="two-column"><div class="form-group"><label>Huyết áp tâm thu</label><input type="number" min="60" max="260" id="log_sbp" class="form-control" value="${todayLog.systolicBp}" placeholder="120"></div><div class="form-group"><label>Huyết áp tâm trương</label><input type="number" min="30" max="180" id="log_dbp" class="form-control" value="${todayLog.diastolicBp}" placeholder="80"></div></div><div class="form-group"><label>Cân nặng (kg)</label><input type="number" min="20" max="300" step="0.1" id="log_weight" class="form-control" value="${todayLog.weight}" placeholder="65"></div><div class="form-group"><label>Triệu chứng hôm nay</label><input id="log_symptoms" class="form-control" maxlength="500" value="${todayLog.symptoms}" placeholder="Mệt mỏi, khát nước, chóng mặt..."></div><div class="form-group"><label>Ghi chú</label><textarea id="log_note" class="form-control" maxlength="1000">${todayLog.note}</textarea></div><button type="button" onclick="saveLog()" class="btn btn-primary" id="saveLogBtn">Lưu chỉ số hôm nay</button><div id="logResult"></div></section><section class="card"><div class="card-title">Truy cập nhanh</div><div class="quick-actions"><a class="btn btn-primary" href="${pageContext.request.contextPath}/PatientAppointments">Đặt lịch khám</a><a class="btn btn-outline-dark" href="${pageContext.request.contextPath}/PatientJournal">Nhật ký sức khỏe</a><a class="btn btn-outline-dark" href="${pageContext.request.contextPath}/PatientHistory">Hồ sơ khám</a></div><c:if test="${not empty latestRecord}"><hr><h3>Bệnh án gần nhất</h3><p>Ngày khám: ${latestRecord.visitDate}</p><p>Chẩn đoán: <c:out value="${latestRecord.finalDiagnosis}" default="Chưa kết luận"/></p></c:if></section></div></c:if></main><jsp:include page="footer.jsp"/><script src="${pageContext.request.contextPath}/static/js/main.js"></script><script>const CTX='${pageContext.request.contextPath}';async function saveLog(){const b=document.getElementById('saveLogBtn'),r=document.getElementById('logResult');b.disabled=true;try{const body=new URLSearchParams({action:'saveLog',bloodGlucose:log_bg.value||'',systolicBp:log_sbp.value||'',diastolicBp:log_dbp.value||'',weight:log_weight.value||'',symptoms:log_symptoms.value||'',note:log_note.value||''});const res=await fetch(CTX+'/PatientHealth',{method:'POST',body});const data=await res.json();r.textContent=data.success?'Đã lưu chỉ số hôm nay.':(data.error||'Không thể lưu dữ liệu.');if(data.success)setTimeout(()=>location.reload(),500)}catch(e){r.textContent='Không thể kết nối máy chủ.'}finally{b.disabled=false}}function ackAlert(id){fetch(CTX+'/PatientHealth',{method:'POST',body:new URLSearchParams({action:'acknowledgeAlert',alertId:id})}).then(x=>{if(x.ok)document.getElementById('alert-'+id)?.remove()})}</script></body></html>
