<%@page contentType="text/html" pageEncoding="UTF-8"%><%@taglib prefix="c" uri="jakarta.tags.core"%>
<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Nhật ký bệnh nhân — DiaCare</title><link rel="stylesheet" href="${pageContext.request.contextPath}/static/css/style.css"></head><body><jsp:include page="header.jsp"/><jsp:include page="topnav.jsp"/><main class="page-wrapper"><div class="page-heading"><div><div class="eyebrow">HỖ TRỢ KHÁM BỆNH</div><h1 class="page-title">Nhật ký sức khỏe — <c:out value="${patient.fullName}"/></h1><p class="text-muted">Dữ liệu bệnh nhân tự ghi trong 30 ngày gần nhất; dùng để tham khảo khi thăm khám.</p></div><a class="btn btn-outline-dark" href="${pageContext.request.contextPath}/ClinicWorkflow">Quay lại lượt khám</a></div><section class="card"><div class="table-scroll"><table><thead><tr><th>Ngày</th><th>Đường huyết</th><th>Huyết áp</th><th>Cân nặng</th><th>Triệu chứng</th><th>Ghi chú</th></tr></thead><tbody><c:forEach var="log" items="${logs}"><tr><td>${log.logDate}</td><td>${empty log.bloodGlucose?'—':log.bloodGlucose}</td><td>${empty log.systolicBp?'—':log.systolicBp}/${empty log.diastolicBp?'—':log.diastolicBp}</td><td>${empty log.weight?'—':log.weight}</td><td><c:out value="${log.symptoms}" default="—"/></td><td><c:out value="${log.note}" default="—"/></td></tr></c:forEach><c:if test="${empty logs}"><tr><td colspan="6" class="empty-state">Bệnh nhân chưa ghi nhật ký sức khỏe.</td></tr></c:if></tbody></table></div></section></main><jsp:include page="footer.jsp"/></body></html>
