<%@taglib prefix="fn" uri="jakarta.tags.functions"%><%@page contentType="text/html" pageEncoding="UTF-8"%><%@taglib prefix="c" uri="jakarta.tags.core"%>
<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Hồ sơ khám — DiaCare</title><link rel="stylesheet" href="${pageContext.request.contextPath}/static/css/style.css?v=20260719-ai1"></head><body><jsp:include page="header.jsp"/><jsp:include page="topnav.jsp"/>
<main class="page-wrapper"><div class="page-heading"><div><div class="eyebrow">DIỄN BIẾN ĐIỀU TRỊ</div><h1 class="page-title">Hồ sơ khám — <c:out value="${patient.fullName}"/></h1><p class="text-muted">Các lần khám được sắp theo thời gian để dễ theo dõi diễn biến bệnh tiểu đường.</p></div><c:if test="${sessionScope.user.role=='PATIENT'}"><a class="btn btn-primary" href="${pageContext.request.contextPath}/PatientAppointments">Đặt lịch khám</a></c:if></div>
<c:if test="${not empty diabetesProfile}"><section class="patient-overview"><div><span>HỒ SƠ TIỂU ĐƯỜNG HIỆN TẠI</span><div>${diabetesProfile.diabetesTypeLabel}</div><p>Điều trị: ${diabetesProfile.treatmentMethodLabel}<c:if test="${not empty diabetesProfile.diagnosisDate}"> · Phát hiện: ${diabetesProfile.diagnosisDate}</c:if><c:if test="${not empty diabetesProfile.hba1cTarget}"> · Mục tiêu HbA1c: ${diabetesProfile.hba1cTarget}%</c:if></p></div></section></c:if>
<div class="record-timeline"><c:forEach var="r" items="${records}"><article class="card timeline-card"><div class="timeline-meta"><div><span class="status-pill status-${r.status}">${r.status=='COMPLETED'?'Đã hoàn tất':'Đang xử lý'}</span><h2>Lần khám #${r.recordId}</h2><p class="text-muted">${r.visitDate}</p></div><a class="btn btn-primary btn-sm" href="${pageContext.request.contextPath}/RecordDetail?id=${r.recordId}">Xem chi tiết</a></div><div class="timeline-body"><div><small>Lý do khám</small><c:out value="${r.reasonForVisit}" default="Chưa ghi nhận"/></div><div><small>Chẩn đoán</small><c:out value="${r.finalDiagnosis}" default="Chưa kết luận"/></div><div><small>Hướng điều trị</small><c:out value="${r.treatmentPlan}" default="Chưa ghi nhận"/></div><div><small>Ngày tái khám</small><c:out value="${r.followUpDate}" default="Theo chỉ định"/></div></div><c:if test="${sessionScope.user.role=='DOCTOR'&&r.status=='DRAFT'}"><a class="btn btn-warning btn-sm" href="${pageContext.request.contextPath}/MedicalRecordForm?recordId=${r.recordId}&tab=4">Tiếp tục khám</a></c:if></article></c:forEach><c:if test="${empty records}"><div class="card empty-state">Chưa có lần khám nào.</div></c:if></div></main><jsp:include page="footer.jsp"/><script src="${pageContext.request.contextPath}/static/js/main.js?v=20260719-ai1"></script></body></html>
