<%@page contentType="text/html" pageEncoding="UTF-8"%><%@taglib prefix="c" uri="jakarta.tags.core"%>
<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Bác sĩ — DiaCare</title><link rel="stylesheet" href="${pageContext.request.contextPath}/static/css/style.css?v=20260717-perf4"></head><body><jsp:include page="header.jsp"/><jsp:include page="topnav.jsp"/><main class="page-wrapper app-workspace">
<div class="workspace-heading"><div><span class="workspace-kicker">KHÔNG GIAN BÁC SĨ</span><h1>Chào buổi làm việc, <c:out value="${sessionScope.user.fullName}"/></h1><p>Ưu tiên lượt khám đang chờ và hoàn tất kết luận trong ngày.</p></div><div class="heading-actions"><a class="btn btn-light" href="${pageContext.request.contextPath}/DoctorProfile">Hồ sơ hành nghề</a><a class="btn btn-primary" href="${pageContext.request.contextPath}/ClinicWorkflow">Mở danh sách lượt khám</a></div></div>
<section class="metric-grid doctor-metrics"><article class="metric-card"><span class="metric-icon blue">♙</span><div><small>BỆNH NHÂN</small><strong>${totalPatients}</strong><p>Trong toàn hệ thống</p></div></article><article class="metric-card"><span class="metric-icon green">▤</span><div><small>BỆNH ÁN CỦA TÔI</small><strong>${totalMyRecords}</strong><p>Tổng hồ sơ đã phụ trách</p></div></article><article class="metric-card urgent"><span class="metric-icon red">!</span><div><small>CẦN KẾT LUẬN</small><strong>${totalPending}</strong><p>Bệnh án đang chờ xử lý</p></div></article></section>
<div class="dashboard-layout"><section class="card dashboard-main"><div class="panel-heading"><div><span class="panel-eyebrow urgent-text">ƯU TIÊN HÔM NAY</span><h2>Bệnh nhân chờ kết luận</h2></div><a href="${pageContext.request.contextPath}/ClinicWorkflow">Xem hàng đợi →</a></div><div class="table-scroll"><table class="modern-table"><thead><tr><th>Bệnh án</th><th>Bệnh nhân</th><th>Lý do khám</th><th>Thời gian</th><th></th></tr></thead><tbody><c:forEach var="r" items="${pendingRecords}"><tr><td><span class="record-code">#${r.recordId}</span></td><td><a class="patient-link" href="${pageContext.request.contextPath}/PatientHistory?patientId=${r.patientId}">Bệnh nhân #${r.patientId}</a></td><td><c:out value="${r.reasonForVisit}"/></td><td>${r.visitDate}</td><td><div class="row-actions"><a href="${pageContext.request.contextPath}/RecordDetail?id=${r.recordId}">Xem</a><a class="primary" href="${pageContext.request.contextPath}/MedicalRecordForm?recordId=${r.recordId}&tab=4">Kết luận</a></div></td></tr></c:forEach><c:if test="${empty pendingRecords}"><tr><td colspan="5" class="empty-state success-empty"><strong>✓ Không còn bệnh án chờ kết luận</strong><span>Các công việc ưu tiên đã được hoàn tất.</span></td></tr></c:if></tbody></table></div></section>
<aside class="dashboard-side"><c:if test="${not empty doctor}"><section class="card doctor-identity"><div class="doctor-avatar"><c:choose><c:when test="${not empty doctor.faceImagePath}"><img src="${pageContext.request.contextPath}/DoctorFile?doctorId=${doctor.doctorId}&type=face"></c:when><c:otherwise>BS</c:otherwise></c:choose></div><h3><c:out value="${sessionScope.user.fullName}"/></h3><p><c:out value="${doctor.specialty}"/></p><dl><div><dt>Chứng chỉ</dt><dd><c:out value="${doctor.licenseNo}"/></dd></div><div><dt>Học vị</dt><dd><c:out value="${doctor.degree}"/></dd></div></dl><a href="${pageContext.request.contextPath}/DoctorProfile">Cập nhật hồ sơ →</a></section></c:if></aside></div>
<section class="card recent-section"><div class="panel-heading"><div><span class="panel-eyebrow">HOẠT ĐỘNG GẦN ĐÂY</span><h2>Bệnh án đã phụ trách</h2></div></div><div class="table-scroll"><table class="modern-table"><thead><tr><th>Mã bệnh án</th><th>Bệnh nhân</th><th>Ngày khám</th><th>Chẩn đoán</th><th>Trạng thái</th><th></th></tr></thead><tbody><c:forEach var="r" items="${myRecords}"><tr><td><span class="record-code">#${r.recordId}</span></td><td>Bệnh nhân #${r.patientId}</td><td>${r.visitDate}</td><td><c:out value="${r.finalDiagnosis}"/></td><td><span class="status-pill status-${r.status}">${r.status}</span></td><td><a href="${pageContext.request.contextPath}/RecordDetail?id=${r.recordId}">Chi tiết →</a></td></tr></c:forEach><c:if test="${empty myRecords}"><tr><td colspan="6" class="empty-state">Chưa có bệnh án gần đây.</td></tr></c:if></tbody></table></div></section></main><jsp:include page="footer.jsp"/></body></html>
